{
  "ckpt":   {"class_type": "CheckpointLoaderSimple", "inputs": {"ckpt_name": "@CKPT@"}},
  "render": {"class_type": "LoadImage", "inputs": {"image": "@RENDER@"}},
  "smap":   {"class_type": "LoadImage", "inputs": {"image": "@SMAP@"}},
  "lock":   {"class_type": "LoadImage", "inputs": {"image": "@LOCKMAP@"}},

  "pos": {"class_type": "CLIPTextEncode", "inputs": {"text": "@POS@", "clip": ["ckpt", 1]}},
  "neg": {"class_type": "CLIPTextEncode", "inputs": {"text": "@NEG@", "clip": ["ckpt", 1]}},

  "depth":   {"class_type": "DepthAnythingV2Preprocessor", "inputs": {"image": ["render", 0], "resolution": @RES@}},
  "lineart": {"class_type": "LineArtPreprocessor", "inputs": {"image": ["render", 0], "resolution": @RES@, "coarse": "disable"}},

  "cn_depth":   {"class_type": "ControlNetLoader", "inputs": {"control_net_name": "control_v11f1p_sd15_depth_fp16.safetensors"}},
  "cn_lineart": {"class_type": "ControlNetLoader", "inputs": {"control_net_name": "control_v11p_sd15_lineart_fp16.safetensors"}},

  "apply_depth": {"class_type": "ControlNetApplyAdvanced", "inputs": {
    "positive": ["pos", 0], "negative": ["neg", 0],
    "control_net": ["cn_depth", 0], "image": ["depth", 0],
    "strength": @CN_DEPTH@, "start_percent": 0.0, "end_percent": 1.0}},

  "apply_lineart": {"class_type": "ControlNetApplyAdvanced", "inputs": {
    "positive": ["apply_depth", 0], "negative": ["apply_depth", 1],
    "control_net": ["cn_lineart", 0], "image": ["lineart", 0],
    "strength": @CN_LINEART@, "start_percent": 0.0, "end_percent": 1.0}},

  "diff":   {"class_type": "DifferentialDiffusion", "inputs": {"model": ["ckpt", 0]}},
  "encode": {"class_type": "VAEEncode", "inputs": {"pixels": ["render", 0], "vae": ["ckpt", 2]}},

  "smask":   {"class_type": "ImageToMask", "inputs": {"image": ["smap", 0], "channel": "red"}},
  "setmask": {"class_type": "SetLatentNoiseMask", "inputs": {"samples": ["encode", 0], "mask": ["smask", 0]}},

  "ksampler": {"class_type": "KSampler", "inputs": {
    "model": ["diff", 0], "seed": @SEED@, "steps": @STEPS@, "cfg": @CFG@,
    "sampler_name": "dpmpp_2m", "scheduler": "karras",
    "positive": ["apply_lineart", 0], "negative": ["apply_lineart", 1],
    "latent_image": ["setmask", 0], "denoise": @DENOISE@}},

  "decode": {"class_type": "VAEDecode", "inputs": {"samples": ["ksampler", 0], "vae": ["ckpt", 2]}},

  "lockmask":  {"class_type": "ImageToMask", "inputs": {"image": ["lock", 0], "channel": "red"}},
  "composite": {"class_type": "ImageCompositeMasked", "inputs": {
    "destination": ["decode", 0], "source": ["render", 0],
    "x": 0, "y": 0, "resize_source": false, "mask": ["lockmask", 0]}},

  "save": {"class_type": "SaveImage", "inputs": {"images": ["composite", 0], "filename_prefix": "calque_gen"}}
}
